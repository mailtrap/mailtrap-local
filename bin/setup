#!/usr/bin/env bash
# Bootstrap a fresh mailtrap-local checkout. Idempotent — safe to re-run.
set -euo pipefail

cd "$(dirname "$0")/.."

say() { printf '\n\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }

# --- toolchain sanity -------------------------------------------------------
need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    warn "Missing '$1'. Install via mise/asdf (see .tool-versions) and re-run."
    exit 1
  fi
}
need go
need node
need npm

# foreman is optional in dev — it's the easiest way to run the Go binary +
# Vite together. Anything else that runs two processes works just as well.
if ! foreman --version >/dev/null 2>&1; then
  if command -v ruby >/dev/null 2>&1 && command -v gem >/dev/null 2>&1; then
    say "Installing foreman gem (used by bin/dev)"
    gem install --user-install foreman

    # `gem install --user-install` puts foreman in ~/.gem/ruby/X.Y.0/bin —
    # not always on PATH. bin/dev adds it automatically; surface a hint
    # here so the user can also run `foreman` directly if they want to.
    user_gem_bin="$(ruby -r rubygems -e 'puts Gem.user_dir + "/bin"' 2>/dev/null || true)"
    if [ -n "$user_gem_bin" ] && [ -d "$user_gem_bin" ]; then
      case ":$PATH:" in
        *":$user_gem_bin:"*) ;;
        *)
          warn "foreman installed at $user_gem_bin/foreman, but that directory"
          warn "is not on your PATH. bin/dev handles this automatically; to use"
          warn "foreman directly, add to your shell config (~/.zshrc or ~/.bashrc):"
          warn "  export PATH=\"$user_gem_bin:\$PATH\""
          ;;
      esac
    fi
  else
    warn "foreman not found and ruby/gem not available. bin/dev needs foreman;"
    warn "either install Ruby + run 'gem install foreman', or run the two"
    warn "Procfile.dev processes manually."
  fi
fi

# --- Go ---------------------------------------------------------------------
say "go mod download"
go mod download

# --- Frontend ---------------------------------------------------------------
say "Frontend: npm install"
(cd frontend && npm install)

# --- Done -------------------------------------------------------------------
cat <<'EOF'

[1;32m==>[0m Setup complete.

    Start the dev stack:   bin/dev
      backend (Go binary): http://127.0.0.1:3550 + SMTP on :3535
      frontend (Vite):     http://127.0.0.1:3540

    Build the single binary:   scripts/build.sh
    Then run it:               bin/mailtrap-local

EOF
